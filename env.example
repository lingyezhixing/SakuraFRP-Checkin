# LLM API 配置（OpenAI 兼容接口）
# 本地部署的 LLM-Node 地址
LLM_BASE_URL=http://127.0.0.1:8080/v1
LLM_API_KEY=your_api_key_here

# 视觉识别模型（用于识别验证码图片）
LLM_MODEL_VISION=Qwen3.5-2B

# 文本模型（用于语义匹配）
LLM_MODEL_TEXT=Qwen3.5-2B

# 定时执行时间（格式：HH:MM，如 08:00）
# 设置后每天在 ±30 分钟内随机执行一次，不设置则执行一次后退出
SCHEDULE_TIME=08:00

# 时区配置
TZ=Asia/Shanghai

# HTTP代理配置（可选）
# 如果服务器需要代理才能访问目标网站，请配置此项
# 例如：HTTP_PROXY=http://127.0.0.1:7890
# 留空表示不使用代理
HTTP_PROXY=
